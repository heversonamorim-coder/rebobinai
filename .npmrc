# OneDrive não lida bem com symlinks — layout hoisted evita problemas de sync
node-linker=hoisted

# Railway usa cache de node_modules e NODE_ENV=production; ao instalar com
# --prod=false o pnpm quer recriar o node_modules e, fora de CI, abre um prompt
# interativo que trava o build. Desliga a confirmação para instalar sem travar.
confirm-modules-purge=false
