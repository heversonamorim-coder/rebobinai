{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "corepack enable && pnpm install --frozen-lockfile && pnpm --filter @rebobinai/api build"
  },
  "deploy": {
    "preDeployCommand": "pnpm --filter @rebobinai/api prisma:deploy",
    "startCommand": "node apps/api/dist/main.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
