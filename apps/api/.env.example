# ============================================================
# Rebobinaí API — variáveis de ambiente
# Copie para .env (nunca commite o .env real)
# ============================================================

# Ambiente: development | test | production
NODE_ENV=development

# Porta da API (web fica na 3000)
PORT=3001

# Origem permitida no CORS (URL do apps/web)
WEB_URL=http://localhost:3000

# --- PostgreSQL (obrigatória) ---
# Local: sobe com `docker compose up -d` na raiz (user/senha/db: rebobinai)
# Staging (Railway): copie a DATABASE_URL do serviço Postgres
DATABASE_URL=postgresql://rebobinai:rebobinai@localhost:5432/rebobinai

# --- Redis (obrigatória) ---
# Serve BullMQ (filas: outbox relay, e-mail, IA, imagem) e cache.
# Nunca é fonte de verdade de domínio.
REDIS_URL=redis://localhost:6379

# --- Cloudflare R2 (módulo media, F3-3) ---
# Painel Cloudflare → R2 → criar bucket + API token (S3 credentials).
# O banco guarda apenas r2Key; binários ficam no R2.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=rebobinai-media
# Domínio público do bucket (custom domain ou r2.dev)
R2_PUBLIC_BASE_URL=

# --- Asaas (módulo payments, F1-5/F1-6) ---
# Sandbox: https://sandbox.asaas.com → Integrações → API key
ASAAS_API_KEY=
# Token que VOCÊ define e configura no webhook do Asaas para validar a origem
ASAAS_WEBHOOK_TOKEN=
# Ambiente do gateway: sandbox (padrão) | production
ASAAS_ENV=sandbox

# --- E-mail transacional (módulo notifications, F1-8; Resend) ---
# https://resend.com → API Keys. Verifique o domínio de envio para produção.
RESEND_API_KEY=
# Remetente (precisa de domínio verificado no Resend em produção)
MAIL_FROM=Rebobinaí ◄◄ <no-reply@rebobinai.app>

# --- Claude API (módulo ai, F3-1) ---
# https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=
# Modelo usado no compositor (padrão: claude-opus-4-8).
ANTHROPIC_MODEL=claude-opus-4-8

# --- Observabilidade (opcional no MVP) ---
SENTRY_DSN=
POSTHOG_KEY=
