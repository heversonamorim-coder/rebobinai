// Rebobinaí ◄◄ — schema Prisma (apps/api)
// Regra do monólito modular: cada tabela tem UM módulo dono; nunca exponha
// o PrismaClient cru entre bounded contexts — cada módulo define seus repositórios.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Padrão outbox — infraestrutura compartilhada de eventos de domínio.
/// Módulos gravam eventos aqui NA MESMA TRANSAÇÃO da escrita de domínio;
/// um relay (BullMQ) publica e marca processedAt. Ex.: gift.paid, gift.viewed, coupon.redeemed.
model OutboxEvent {
  id            String    @id @default(cuid())
  eventType     String // ex.: "gift.paid"
  aggregateType String // ex.: "Gift"
  aggregateId   String
  payload       Json
  createdAt     DateTime  @default(now())
  processedAt   DateTime?
  attempts      Int       @default(0)
  lastError     String?

  @@index([processedAt, createdAt])
  @@index([aggregateType, aggregateId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Módulo: gift (dono das tabelas Gift e GiftAsset)
// Ciclo de vida: draft (guest, com marca d'água) → paid (slug público, sem marca)
//   → archived. O slug público só é gerado ao pagar (anti-abuso). Guest-first:
//   o rascunho é acessado por editToken, sem login.
// ─────────────────────────────────────────────────────────────────────────────

enum GiftStatus {
  draft
  paid
  archived
}

enum GiftAssetType {
  image
  audio
}

model Gift {
  id             String     @id @default(cuid())
  slug           String?    @unique // curto e permanente; só é gerado ao pagar
  status         GiftStatus @default(draft)
  ownerAccountId String? // vínculo opcional de conta (Fase 2); guest-first
  editToken      String     @unique @default(cuid()) // acesso do guest ao rascunho
  occasion       String? // ex.: "dia-dos-pais", "namorada"
  payload        Json       @default("{}") // conteúdo (título, carta, timeline...)
  watermark      Boolean    @default(true) // removida ao pagar
  viewCount      Int        @default(0) // contador ao vivo da página pública (F1-3)
  paidAt         DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  assets GiftAsset[]

  @@index([status, createdAt])
  @@index([ownerAccountId])
}

model GiftAsset {
  id        String        @id @default(cuid())
  giftId    String
  gift      Gift          @relation(fields: [giftId], references: [id], onDelete: Cascade)
  type      GiftAssetType
  r2Key     String // chave no Cloudflare R2 (upload em F3-3)
  order     Int           @default(0)
  createdAt DateTime      @default(now())

  @@index([giftId, order])
}

// ─────────────────────────────────────────────────────────────────────────────
// Módulo: promotions (dono da tabela Plan)
// Preço de lançamento dirigido por dado (compliance CDC/Procon): o preço "de"
// tachado é o fullPrice real e futuro; launchEndsAt é a data em que o preço
// sobe. Enquanto launchEndsAt for nulo, mostra-se "preço de lançamento" sem
// afirmar prazo — nada de deadline fabricado.
// ─────────────────────────────────────────────────────────────────────────────

enum PlanKey {
  free
  digital
  forever
  quadro
}

model Plan {
  id           String    @id @default(cuid())
  key          PlanKey   @unique
  name         String
  tagline      String?
  fullPrice    Int // centavos — preço-alvo (cheio)
  launchPrice  Int // centavos — preço de lançamento (== fullPrice quando sem promo)
  launchEndsAt DateTime? // quando o preço sobe para fullPrice; nulo = sem prazo anunciado
  features     String[] // itens inclusos no plano
  active       Boolean   @default(true)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Módulo: payments (dono da tabela Order)
// Guarda só o giftId (não cruza tabelas do gift). O gateway (Asaas) é a fonte
// de verdade do pagamento; refs ficam em gatewayId. A liberação do presente
// acontece no webhook (F1-6), chamando o serviço exportado do módulo gift.
// ─────────────────────────────────────────────────────────────────────────────

enum OrderStatus {
  pending
  paid
  failed
  canceled
  refunded
}

model Order {
  id            String      @id @default(cuid())
  giftId        String
  planKey       PlanKey
  amountCharged Int // centavos efetivamente cobrados
  gateway       String      @default("asaas")
  gatewayId     String? // id da cobrança no gateway (Asaas payment id)
  status        OrderStatus @default(pending)
  billingType   String? // PIX | CREDIT_CARD
  customerEmail String?

  // ── Produto físico (plano "Lembrança física", Tarefa 5) ──────────────────
  productKey    String? // 'caneca' | 'camiseta' (nulo em planos digitais)
  productSize   String? // tamanho da camiseta: P | M | G | GG (nulo na caneca)
  photoAssetId  String? // foto escolhida p/ a caneca (id de um GiftAsset)
  shipping      Json? // endereço de entrega { name, phone, cep, street, number, ... }
  shippingCost  Int? // frete em centavos (calculado por CEP no checkout)
  // Fulfillment (Tarefa 6) — preenchidos pelo admin ao despachar.
  trackingCode  String? // código de rastreio dos Correios
  shippedAt     DateTime?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  paidAt        DateTime?

  @@index([giftId])
  @@index([gatewayId])
  @@index([status, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Módulo: gallery (dono da tabela Example)
// Exemplos prontos por persona. "Usar como base" clona o payload num rascunho
// novo (via GiftService) — mata a folha em branco e acelera a criação (F2-5).
// O seoSlug alimenta as páginas de ocasião (F2-6).
// ─────────────────────────────────────────────────────────────────────────────

model Example {
  id        String   @id @default(cuid())
  persona   String // ex.: "namorada", "pai"
  name      String // rótulo exibido, ex.: "Pra namorada"
  occasion  String?
  payload   Json
  seoSlug   String   @unique
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active, sortOrder])
}

// ─────────────────────────────────────────────────────────────────────────────
// Módulo: contact (dono da tabela ContactMessage)
// "Fale conosco" do rodapé: mensagens do público ficam salvas e são lidas no
// admin. Sem PII sensível além de nome/e-mail informados pelo próprio cliente.
// ─────────────────────────────────────────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  handled   Boolean  @default(false) // marcado como tratado no admin
  createdAt DateTime @default(now())

  @@index([handled, createdAt])
}
