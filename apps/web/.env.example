# URL da API (NestJS) em dev
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Admin de vendas (rota /admin, Tarefa 6) ---
# Base da API no lado do servidor (não usa NEXT_PUBLIC pra não vazar no browser).
# Se ausente, cai no NEXT_PUBLIC_API_URL.
API_URL=http://localhost:3001
# Login do operador do painel /admin.
ADMIN_USER=
ADMIN_PASSWORD=
# Token compartilhado com a API (igual ao ADMIN_API_TOKEN do apps/api). O cookie
# de sessão guarda este segredo; as chamadas à API saem do servidor com ele.
ADMIN_API_TOKEN=

# --- Analytics & Observabilidade (Tarefas 3 e 4) — todos opcionais ---
# Google Analytics 4: cole o ID de medição (formato G-XXXXXXX). Sem ele, o GA
# não carrega.
NEXT_PUBLIC_GA_ID=
# Sentry (erros no navegador). Use o DSN do projeto "browser"/JS do Sentry.
NEXT_PUBLIC_SENTRY_DSN=
# PostHog (funil de produto): chave de projeto + host da sua região.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
